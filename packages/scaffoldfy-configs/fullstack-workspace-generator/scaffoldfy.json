{
  "$schema": "../node_modules/@pixpilot/scaffoldfy/schema/scaffoldfy.schema.json",
  "name": "fullstack-workspace-generator",
  "description": "Generate a full-stack workspace with optional Next.js, Supabase, Drizzle, Chrome Extension, Storybook, and Cloudflare support",
  "extends": [
    "./scaffoldfy-prompts.json",
    "../project-info/scaffoldfy.json",
    "../license-file/scaffoldfy.json"
  ],
  "variables": [
    {
      "id": "relativePackagesPath",
      "value": "../../"
    },
    {
      "id": "relativeAppsPath",
      "value": "../../"
    },
    {
      "id": "relativeToolingPath",
      "value": "../../"
    },
    {
      "id": "relativeSupabasePath",
      "value": "../"
    },
    {
      "id": "addTrpc",
      "value": {
        "type": "conditional",
        "condition": "addNextJs === true",
        "ifTrue": true,
        "ifFalse": false
      }
    },
    {
      "id": "licenceFilePath",
      "value": "LICENSE"
    },
    {
      "id": "packageOrgName",
      "value": {
        "type": "interpolate",
        "value": "{{orgName}}"
      },
      "transformers": ["kebabcase"]
    }
  ],

  "tasks": [
