{
  "extends": "./tooling/typescript/base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["packages/ui/src/*"]
    },
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "checkJs": false,
    "strict": true,
    "noEmit": false
  },
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    "**/.cache/**",
    "**/build/**",
    "coverage",
    "**/dist/**",
    "**/*.js"
  ]
}
