{
  "name": "@internal/api-client",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "license": "NONE",
  "exports": {
    ".": "./src/index.ts",
    "./vanilla": "./src/vanilla-client.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist",
    "clean:all": "pnpm clean && git clean -xdf node_modules",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@internal/api": "workspace:*",
    "@internal/utils": "workspace:*",
    {{#if addTrpc}}
    "@trpc/client": "catalog:prod",
    "@trpc/react-query": "catalog:prod",
    "superjson": "^2.2.6",
    {{/if}}
    "@tanstack/react-query": "^5.90.21",
    "react": "catalog:prod",
    "react-dom": "catalog:prod"
  },
  "devDependencies": {
    "@internal/eslint-config": "workspace:*",
    "@internal/prettier-config": "workspace:*",
    "@internal/tsconfig": "workspace:*",
    "@internal/vitest-config": "workspace:*",
    "@types/node": "catalog:dev",
    "@types/react": "catalog:dev",
    "eslint": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "prettier": "@internal/prettier-config"
}
