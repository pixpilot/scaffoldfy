{
  "name": "@internal/api",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "license": "NONE",
  "exports": "./src/index.ts",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist",
    "clean:all": "pnpm clean && git clean -xdf node_modules",
    "test": "vitest --run --passWithNoTests",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@internal/configs": "workspace:*",
    "@internal/utils": "workspace:*",
    {{#if addDrizzle}}
    "@internal/database": "workspace:*",
    "drizzle-zod": "catalog:prod",
    {{/if}}
    {{#if addSupabase}}
    "@api/supabase": "workspace:*",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "catalog:prod",
    {{/if}}
    {{#if addTrpc}}
    "@trpc/server": "catalog:prod",
    "superjson": "^2.2.6",
    {{/if}}
    "zod": "catalog:prod"
  },
  "devDependencies": {
    "@internal/eslint-config": "workspace:*",
    "@internal/prettier-config": "workspace:*",
    "@internal/tsconfig": "workspace:*",
    "@internal/vitest-config": "workspace:*",
    "@types/node": "catalog:dev",
    "eslint": "catalog:dev",
    {{#if addNextJs}}
    "next": "catalog:prod",
    {{/if}}
    "typescript": "catalog:dev"
  },
  "prettier": "@internal/prettier-config"
}