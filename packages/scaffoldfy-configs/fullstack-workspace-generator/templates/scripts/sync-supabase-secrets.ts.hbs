import process from 'node:process';
import * as dotenv from 'dotenv';

dotenv.config({ path: ['.env', '.env.production'] });

const SUPABASE_URL = process.env.SUPABASE_URL;
const SUPABASE_SERVICE_ROLE_KEY = process.env.SUPABASE_SERVICE_ROLE_KEY;
const EDGE_PROXY_REQUEST_KEY = process.env.EDGE_PROXY_REQUEST_KEY;
const SUPABASE_ACCESS_TOKEN = process.env.SUPABASE_ACCESS_TOKEN;
const SUPABASE_PROJECT_REF = process.env.SUPABASE_PROJECT_REF;

if (!SUPABASE_URL || !SUPABASE_SERVICE_ROLE_KEY || !EDGE_PROXY_REQUEST_KEY) {
  console.error('Missing required env vars');
  console.error(
    'Required: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, EDGE_PROXY_REQUEST_KEY',
  );
  process.exit(1);
}

if (!SUPABASE_ACCESS_TOKEN || !SUPABASE_PROJECT_REF) {
  console.error('Missing Supabase Management API credentials');
  console.error('Required: SUPABASE_ACCESS_TOKEN, SUPABASE_PROJECT_REF');
  throw new Error(
    'Set SUPABASE_ACCESS_TOKEN and SUPABASE_PROJECT_REF in env vars',
  );
}

async function setEdgeFunctionsSecret() {
  const response = await fetch(
    `https://api.supabase.com/v1/projects/${SUPABASE_PROJECT_REF}/secrets`,
    {
      method: 'POST',
      headers: {
        Authorization: `Bearer ${SUPABASE_ACCESS_TOKEN}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify([
        {
          name: 'EDGE_PROXY_REQUEST_KEY',
          value: EDGE_PROXY_REQUEST_KEY,
        },
      ]),
    },
  );

  if (!response.ok) {
    const errorText = await response.text();
    throw new Error(
      `API request failed: ${response.status} - ${errorText}`,
    );
  }

  console.log('Edge Function secret configured successfully');
}

async function syncConfig() {
  try {
    console.log('Setting Supabase Secret...');
    await setEdgeFunctionsSecret();
  } catch (err) {
    console.error('Failed to set Edge Function secret:', err);
    throw err;
  }
}

syncConfig();
